TAIL_LINES=1000

tmux-conf() {
  cat << 'EOF'
# --- General Settings ---
set-option mouse on               # Enable mouse for scrolling/clicking if desired
set-option history-limit 50000    # Generous scrollback buffer

# --- Pane Title / Status Line Configuration ---
set-option pane-border-status top
set-option pane-border-format "#[fg=black,bg=cyan,bold] #{pane_title} #[default]"
set-option pane-border-style "fg=colour238,bg=default"
set-option pane-active-border-style "fg=colour238,bg=cyan"

bind-key -n q kill-session
bind-key -n Q kill-session
bind-key -n : command-prompt

# --- One-Key Pane Navigation ---
bind-key -n M-Up 'select-pane -U; run-shell "tmtail -P #{pane_id} -X distribute-active50"'
bind-key -n M-Down 'select-pane -D; run-shell "tmtail -P #{pane_id} -X distribute-active50"'
bind-key -n M-k 'select-pane -U; run-shell "tmtail -P #{pane_id} -X distribute-active50"'
bind-key -n M-j 'select-pane -D; run-shell "tmtail -P #{pane_id} -X distribute-active50"'
bind-key -n Left select-pane -L
bind-key -n Right select-pane -R
bind-key -n Up select-pane -U
bind-key -n Down select-pane -D
bind-key -n k select-pane -U
bind-key -n j select-pane -D
bind-key -n _ resize-pane -y 90%          # Maximise pane
bind-key -n = select-layout even-vertical # Even out panes
bind-key -n U select-layout even-vertical # Even out panes'
bind-key -n Escape select-layout even-vertical # Even out panes'
bind-key -n M-= select-layout tiled # Even out panes
bind-key -n z resize-pane -Z
bind-key -n h display-popup -E -T 'Command keys' -w 65 -h 27 -x C -y C tmtail -X show-help
bind-key -n ? display-popup -E -T 'Command keys' -w 65 -h 27 -x C -y C tmtail -X show-help

# --- Copy Mode & Navigation ---
bind-key -n B 'run-shell "#{?pane_zoomed_flag,,tmux resize-pane -Z;} tmux copy-mode"'
set-option -w -g mode-keys vi
bind-key -T copy-mode-vi Escape run-shell 'tmux send -X cancel; tmux select-layout even-vertical'
bind-key -T copy-mode-vi U run-shell 'tmux send -X cancel; tmux select-layout even-vertical'
bind-key -T copy-mode-vi B send -X halfpage-up
bind-key -T copy-mode-vi F send -X halfpage-down
bind-key -T copy-mode-vi y send -X copy-selection
bind-key -T copy-mode-vi Y send -X copy-line
bind-key -T copy-mode-vi v send -X select-word

#bind -n u choose-tree -F "#[fg=blue,bold]#{pane_title}#[default] (Pane #{pane_index}) -> #{pane_current_command}" \
#                       "select-pane -t %1; resize-pane -y 90%"

# --- 'u' to bring up a stable popup menu to choose and maximize a pane ---
bind-key -n u run-shell 'tmtail -X select-for-maximize #{client_name}'
# --- '+' to make current pane 50% height and distribute the rest evenly ---
bind-key -n + run-shell 'tmtail -P #{pane_id} -X distribute-active50'
# --- One-Key Marker Line (All Panes + Solid Background) ---
bind-key -n Enter run-shell 'tmtail -X add-marker'
bind-key -n Space run-shell 'tmtail -X add-marker'
EOF
}

show-help() {
  cat << 'EOF'

  Up,k        Select next pane up
  Down,j      Select next pane down
  Left        Select next pane left
  Right       Select next pane right
  M-Up,M-k    Select next pane up and set height to 50%
  M-Down,M-j  Select next pane down and set height to 50%
  +           Set pane height to 50%
  _           Set pane height to 90%
  =,U,Escape  Show all panes in equal height
  M-=         Show panes tiled
  z           Zoom pane
  u           Select pane from a menu to zoom (but not scroll)
  B           Zoom pane (if not) and enter scrollback mode
  B           One halfpage back if in scrollback mode already
  F           One halfpage forward if in scrollback mode
  y           Yank. Copy selection to clipboard
  Y           Yank line to clipboard
  ?,/,n,N,V   Search etc. in scrollback mode.
              See man tmux / copy-mode for others
  h,?         Show this help text
  Enter,Space Add a marker line to all panes
  :           Enter the tmux command prompt
  q,Q         quit
EOF
  read -n 1 X
}

main() {
  # --- Environment Protection ---
  unset TMUX
  unset TMUX_PANE
  export TSESS=tmtail-$$

  # Default tail history count

  # Start the tmux session with the first file
  FIRST_FILE="$1"
  FIRST_CMD="tmtail -X tail_cmd \"$FIRST_FILE\" \"$TAIL_LINES\""
  tmux -f <(tmux-conf) new-session -d -s "$TSESS" -n "tmtail log monitor" "$FIRST_CMD"
  tmux select-pane -t "$TSESS.0" -T "$(basename "$FIRST_FILE")"
  tmux set-option -t $TSESS history-limit $(( TAIL_LINES * 10 ))


  # Loop through the remaining files and split the panes
  shift
  pane_index=1
  for file in "$@"; do
      CMD="tmtail -X tail_cmd \"$file\" \"$TAIL_LINES\""
      tmux split-window -t "$TSESS" -v "$CMD"
      tmux select-pane -t "$TSESS.$pane_index" -T "$(basename "$file")"
      tmux select-layout -t "$TSESS" even-vertical
      ((pane_index++))
  done
  tmux select-pane -t "$TSESS.0"

  # Attach to the created session
  tmux attach-session -t "$TSESS"
}

# Function to pick a highlighter and append tail parameters
tail_cmd() {
  local file="$1"
  local lines="$2"
  trap 'stty echoctl' EXIT
  stty -echoctl
  if [ $COLOR_CONFIG ] ;then
    tail -n $lines -F "$file" | grcat.js $COLOR_CONFIG
  else
    tail -n $lines -F "$file" | grcat.js <(grcat_conf)
  fi
}


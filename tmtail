select-for-maximize() {
    menu_args=()
    menu_args+=("Select log pane to maximize" 0 0)

    idx=1
    while read -r pid title; do \
        # Each menu item: "Label" "Shortcut Key" "Command to execute" \
        menu_args+=("($idx) $title" "$idx" "resize-pane -t $pid -Z")
        ((idx++))
    done < <(tmux list-panes -F "#{pane_id} #{pane_title}")

    tmux display-menu -c $1 -t $TSESS -T "Log Files" "${menu_args[@]}"
}

distribute-active50() {
  current_pane_id=$TPANE
  total_height=$(tmux display-message -p "#{window_height}")

  target_height=$(( total_height / 2 ))
  other_height=$(( total_height - target_height ))

  pane_count=$(tmux list-panes -F "#{pane_id}" | wc -l)
  if [ "$pane_count" -gt 1 ]; then \
    pane_share=$(( other_height / (pane_count - 1) ))
    if [ "$pane_share" -lt 2 ]; then pane_share=2; fi
      for pid in $(tmux list-panes -F "#{pane_id}" | grep -v "^${current_pane_id}$"); do \
        tmux resize-pane -t "$pid" -y "$pane_share"
      done
  fi
  tmux resize-pane -t "$current_pane_id" -y "$target_height"
}

add-marker() {
  panes=$(tmux list-panes -t $TSESS -F "#{pane_id}")
  timestamp=$(date +" %Y-%m-%d %H:%M:%S ")
  if tmux paste-buffer -S -b "nonexistent_test_buffer" 2>&1 | grep -q "unknown flag"; then
    raw_flag=""
  else
    raw_flag="-S"
  fi

  for pid in $panes; do \
    width=$(tmux display-message -t "$TSESS.$pid" -p "#{pane_width}")
    half_width=$(( (width - ${#timestamp}) / 2 ))
    if [ $half_width -le 0 ]; then half_width=1; fi

    marker_line=$(printf "%*s" $half_width '')
    marker_line="${marker_line}${timestamp}"
    rem_width=$(( width - ${#marker_line}))
    if [ $rem_width -gt 0 ] ;then
      marker_line="${marker_line}$(printf "%*s" $rem_width '')"
    fi

     tmux set-buffer -t $TSESS -b LINE "$(printf "\033[34m\033[1;103m%s\033[0m\n" "$marker_line")"
     tmux paste-buffer $raw_flag -t $TSESS.$pid -b LINE
    done
}

usage() {
  echo "Usage: ${0##*/} [-n lines] [-c colorconf] <file1> [file2] [file3] ..."
  exit 1
}

while getopts "n:c:P:X:x" opt; do
  case "$opt" in
    n) TAIL_LINES=$OPTARG ;;
    c) COLOR_CONFIG=$OPTARG ;;
    P) TPANE=$OPTARG ;;
    X) XOP="$OPTARG" ;;
    x) set -x ;;
    *) usage ;;
  esac
done
shift $((OPTIND-1))

if [ $XOP ] ;then
  $XOP "$@"
  exit $?
fi

# Usage check for files
[ "$#" -ge 1 ] || usage
main "$@"

